{
  "manifest_version": 3,
  "name": "LinkedIn Bucket Saver",
  "version": "3.0",
  "description": "Personal CRM directly inside LinkedIn profiles.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Bucket Saver"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
